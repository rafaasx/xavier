{
  "name": "xavier",
  "private": true,
  "scripts": {
    "build": "npm --prefix frontend run build",
    "test": "npm --prefix frontend test -- --watch=false --browsers=ChromeHeadless",
    "backend:typecheck": "tsc --project backend/tsconfig.json --noEmit",
    "backend:generate": "prisma generate --schema backend/prisma/schema.prisma",
    "backend:migrate:dev": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "backend:migrate:deploy": "prisma migrate deploy --schema backend/prisma/schema.prisma",
    "backend:seed": "tsx backend/prisma/seed.ts",
    "postinstall": "prisma generate --schema backend/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "@vercel/node": "^5.1.12",
    "bcryptjs": "^3.0.2",
    "jose": "^6.0.11",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "prisma": "^6.6.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}

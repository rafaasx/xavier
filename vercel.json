{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm --prefix frontend run build",
  "outputDirectory": "frontend/dist/frontend/browser",
  "functions": {
    "api/**/*.ts": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
